{
  "name": "event-booking-system",
  "version": "0.0.0",
  "homepage": "https://vicky-2507.github.io/Event-Booking-App/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:github": "ng build --configuration production --base-href /Event-Booking-App/ && powershell -NoProfile -Command \"Copy-Item dist/Event-Booking-System/browser/index.html dist/Event-Booking-System/browser/404.html\"",
    "deploy": "npm run build:github && npx angular-cli-ghpages --dir=dist/Event-Booking-System/browser",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "ngx-editor": "^19.0.0-beta.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-cli-ghpages": "^3.1.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
